<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hyper_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/materiales_form_title_create"
            android:textColor="@color/hyper_on_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Título -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tituloLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/materiales_form_titulo"
            app:layout_behavior="com.google.android.material.textfield.OutlinedBox"
            app:boxStrokeColor="@color/hyper_accent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/hyper_on_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Descripción -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/descripcionLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/materiales_form_descripcion"
            app:layout_behavior="com.google.android.material.textfield.OutlinedBox"
            app:boxStrokeColor="@color/hyper_accent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:textColor="@color/hyper_on_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Tipo (Spinner) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/materiales_form_tipo"
            android:textColor="@color/hyper_on_primary"
            android:textSize="16sp" />

        <Spinner
            android:id="@+id/spinnerTipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/spinner_background"
            android:padding="8dp"
            android:textColor="@color/hyper_on_primary" />

        <!-- URL -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/urlLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/materiales_form_url"
            app:layout_behavior="com.google.android.material.textfield.OutlinedBox"
            app:boxStrokeColor="@color/hyper_accent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:maxLines="1"
                android:textColor="@color/hyper_on_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/materiales_form_guardar"
            app:backgroundTint="@color/hyper_accent"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>
