<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hyper_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mensajes_compose_title"
            android:textColor="@color/hyper_on_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Para (To) Deportista Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDestinatario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/mensajes_form_para"
            app:boxStrokeColor="@color/hyper_accent"
            app:hintTextColor="@color/hyper_accent">

            <Spinner
                android:id="@+id/spinnerDestinatario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_background"
                android:padding="8dp"
                android:textColor="@color/hyper_on_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Mensaje (Content) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/mensajes_form_contenido"
            app:boxStrokeColor="@color/hyper_accent"
            app:hintTextColor="@color/hyper_accent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etContenido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:minLines="5"
                android:textColor="@color/hyper_on_primary"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressLoading"
            style="?android:attr/progressBarStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="gone" />

        <!-- Send Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/mensajes_send_button"
            app:backgroundTint="@color/hyper_accent"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>
