{
  "info": {
    "name": "Hyper Reset - Permission Testing",
    "description": "Testing suite para validar permisos de Deportista y Coach",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Auth - Login Deportista",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  var jsonData = pm.response.json();",
              "  pm.environment.set('DEPORTISTA_TOKEN', jsonData.data.token);",
              "  pm.environment.set('DEPORTISTA_ID', jsonData.data.id);",
              "  console.log('✅ Deportista token saved');",
              "} else {",
              "  console.log('❌ Login failed: ' + pm.response.code);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"deportista@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/auth/login",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "🔐 Auth - Login Coach",
      "event": [
        {
          "listen": "test",
          "script": {
