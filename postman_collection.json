        },
        "url": {
          "raw": "{{BASE_URL}}/api/auth/login",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "✅ TEST 1.1: GET /api/citas (Deportista)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has data array', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.data).to.be.an('array');",
              "});",
              "pm.test('Each cita has required fields', function () {",
              "  var jsonData = pm.response.json();",
              "  jsonData.data.forEach(function(cita) {",
              "    pm.expect(cita).to.have.property('id');",
              "    pm.expect(cita).to.have.property('fecha');",
              "  });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{DEPORTISTA_TOKEN}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/citas",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "citas"]
        }
      }
    },
    {
      "name": "✅ TEST 1.2: PUT /api/deportistas/{id} (Edit own profile)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Email was updated', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.data.email).to.equal('deportista.new@email.com');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{DEPORTISTA_TOKEN}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"deportista.new@email.com\",\n  \"telefono\": \"+34 600 999 888\",\n  \"direccion\": \"Calle Nueva 456\",\n  \"coachId\": 50\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/deportistas/{{DEPORTISTA_ID}}",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "deportistas", "{{DEPORTISTA_ID}}"]
        }
      }
    },
